# Copy to .env for local dev, or set these in the Railway "Variables" tab.
# If SUPABASE_* are omitted, the server falls back to local JSON files (./data).

# --- Supabase (production database) ---
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# SERVICE ROLE key (Supabase dashboard → Settings → API → service_role).
# Server-side ONLY. Never expose this to the browser or commit a real value.
SUPABASE_SERVICE_KEY=

# --- Server ---
# PORT is provided automatically by Railway; 3000 is the local default.
# PORT=3000
# DATA_DIR only matters for the JSON-file fallback; on Railway set it to your
# mounted volume path if you ever run without Supabase. Ignored when Supabase is on.
# DATA_DIR=./data
