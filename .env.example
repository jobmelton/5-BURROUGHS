# Copy to .env for local dev, or set these in the Railway "Variables" tab.
# If DATABASE_URL is omitted, the server falls back to local JSON files (./data).

# --- Database (Supabase Postgres) ---
# The full connection string (URI). Supabase dashboard:
#   Project → Settings → Database → Connection string → URI
# Includes your DB password. Server-side ONLY — never in the browser or the repo.
# Schema is applied automatically from migrations/ on startup.
DATABASE_URL=

# --- Server ---
# PORT is provided automatically by Railway; 3000 is the local default.
# PORT=3000
# DATA_DIR only matters for the JSON-file fallback (when DATABASE_URL is unset).
# DATA_DIR=./data
